import 'package:flutter/material.dart';

class EventPhotoGallery extends StatefulWidget {
  final int eventId;

  const EventPhotoGallery({super.key, required this.eventId});

  @override
  State<EventPhotoGallery> createState() => _EventPhotoGalleryState();
}

class _EventPhotoGalleryState extends State<EventPhotoGallery> {
  final int itemsPerPage = 4;
  int currentPage = 0;

  // TODO: Replace with real data from database
  List<Map<String, dynamic>> mockPhotos = List.generate(
    12,
    (index) => {
      'id': index,
      'eventid': 1,
      'userid': 101,
      'image_url': 'https://picsum.photos/200?image=${index + 10}',
      'created_at': DateTime.now().subtract(Duration(days: index)),
    },
  );

  List<Map<String, dynamic>> get currentPagePhotos {
    final filteredPhotos = mockPhotos
        .where((photo) => photo['eventid'] == widget.eventId)
        .toList()
      ..sort((a, b) =>
          (b['created_at'] as DateTime).compareTo(a['created_at'] as DateTime));

    final start = currentPage * itemsPerPage;
    final end = (start + itemsPerPage).clamp(0, filteredPhotos.length);
    return filteredPhotos.sublist(start, end);
  }

  int get totalPages {
    final count = mockPhotos
        .where((photo) => photo['eventid'] == widget.eventId)
        .length;
    return (count / itemsPerPage).ceil();
  }

  void _nextPage() {
    if (currentPage < totalPages - 1) {
      setState(() => currentPage++);
    }
  }

  void _prevPage() {
    if (currentPage > 0) {
      setState(() => currentPage--);
    }
  }

  @override
  Widget build(BuildContext context) {
    final photos = currentPagePhotos;

    return Column(
      children: [
        GridView.builder(
          shrinkWrap: true,
          physics: NeverScrollableScrollPhysics(),
          itemCount: photos.length,
          padding: const EdgeInsets.all(8),
          gridDelegate: const SliverGridDelegateWithFixedCrossAxisCount(
            crossAxisCount: 2,
            crossAxisSpacing: 10,
            mainAxisSpacing: 10,
          ),
          itemBuilder: (context, index) {
            final photo = photos[index];
            return ClipRRect(
              borderRadius: BorderRadius.circular(12),
              child: Image.network(
                photo['image_url'],
                fit: BoxFit.cover,
              ),
            );
          },
        ),

        const SizedBox(height: 16),

        Row(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            ElevatedButton(
              onPressed: _prevPage,
              child: const Icon(Icons.arrow_back),
            ),
            const SizedBox(width: 20),
            Text('Page ${currentPage + 1} of $totalPages'),
            const SizedBox(width: 20),
            ElevatedButton(
              onPressed: _nextPage,
              child: const Icon(Icons.arrow_forward),
            ),
          ],
        ),
      ],
    );
  }
}
